# ── Azure AI Services (Computer Vision + Language) ────────────────────────────
AZURE_FACE_API_KEY=your_azure_ai_services_key_here
AZURE_FACE_ENDPOINT=https://your-resource-name.cognitiveservices.azure.com

# ── AWS DynamoDB ───────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1

# DynamoDB table names (auto-created on first startup)
DYNAMODB_USERS_TABLE=stressdetect-users
DYNAMODB_SESSIONS_TABLE=stressdetect-sessions
DYNAMODB_JOURNAL_TABLE=stressdetect-journal

# Optional: DynamoDB Local for offline dev/testing
# DYNAMODB_ENDPOINT_URL=http://localhost:8000

# ── App ────────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret
ENVIRONMENT=production
PORT=8001
ALLOWED_ORIGINS=https://your-frontend-domain.com
